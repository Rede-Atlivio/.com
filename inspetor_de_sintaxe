<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlivio Code X-Ray V2 | Perícia Estrutural</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { background-color: #020617; color: #cbd5e1; font-family: 'JetBrains Mono', monospace; overflow: hidden; }
        
        /* Container Principal */
        .editor-container { position: relative; flex: 1; display: flex; background: #0f172a; overflow: hidden; border-right: 1px solid #1e293b; }
        
        /* Área de Digitação Invisível (Camada de Cima) */
        #inputCode {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: transparent; color: transparent; caret-color: white;
            z-index: 10; padding: 20px 20px 20px 60px;
            resize: none; outline: none; border: none;
            line-height: 20px; font-size: 13px; white-space: pre; font-family: inherit;
        }

        /* Camada Visual de Renderização (Camada de Baixo) */
        #highlightArea {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 5; padding: 20px 20px 20px 60px;
            pointer-events: none; line-height: 20px; font-size: 13px;
            white-space: pre; font-family: inherit; color: #94a3b8;
        }

        /* Numeração de Linhas */
        #lineNumbers {
            width: 50px; background: #020617; color: #334155;
            padding: 20px 10px; text-align: right; font-size: 11px;
            line-height: 20px; user-select: none; border-right: 1px solid #1e293b;
        }

        /* Estilo da Linha com Erro */
        .error-highlight {
            background: rgba(220, 38, 38, 0.4);
            display: inline-block; width: 100%;
            border-left: 3px solid #ef4444; color: #fee2e2;
        }

        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 5px; }
    </style>
</head>
<body class="h-screen flex flex-col">

    <header class="bg-slate-900 border-b border-slate-800 p-4 flex justify-between items-center h-20 shrink-0 z-50">
        <div class="flex items-center gap-4">
            <div id="status-ball" class="w-4 h-4 rounded-full bg-slate-700 animate-pulse"></div>
            <div>
                <h1 class="text-xl font-black text-white uppercase italic tracking-tighter">Atlivio <span class="text-indigo-500">Perícia</span></h1>
                <p id="status-msg" class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Scanner de 10k Linhas Ativado</p>
            </div>
        </div>
        <button onclick="window.location.reload()" class="px-6 py-2 bg-red-600 hover:bg-red-500 text-white text-[10px] font-black uppercase rounded-lg transition-all">Limpar Tudo</button>
    </header>

    <main class="flex-1 flex overflow-hidden">
        <!-- LADO ESQUERDO: EDITOR COM NÚMEROS E MARCAÇÃO -->
        <div class="editor-container">
            <div id="lineNumbers">1</div>
            <div id="highlightArea"></div>
            <textarea id="inputCode" spellcheck="false" oninput="sincronizarEditor()" onscroll="sincronizarScroll()"></textarea>
        </div>

        <!-- LADO DIREITO: EXPLICAÇÃO -->
        <div class="w-[400px] bg-slate-950 flex flex-col p-6 space-y-6 overflow-y-auto z-50 shadow-2xl border-l border-white/5">
            <h2 class="text-xs font-black text-indigo-400 uppercase tracking-widest border-b border-indigo-500/20 pb-2">Diagnóstico da Falha</h2>
            
            <div id="diagnostico" class="space-y-4">
                <div class="opacity-30 text-center py-20">
                    <p class="text-4xl mb-4">🔬</p>
                    <p class="text-[10px] uppercase font-bold">Aguardando colagem do código para análise estrutural...</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        const input = document.getElementById('inputCode');
        const highlight = document.getElementById('highlightArea');
        const lineNumbers = document.getElementById('lineNumbers');
        const diagnostico = document.getElementById('diagnostico');
        const ball = document.getElementById('status-ball');
        const statusMsg = document.getElementById('status-msg');

        function sincronizarScroll() {
            highlight.scrollTop = input.scrollTop;
            highlight.scrollLeft = input.scrollLeft;
            lineNumbers.scrollTop = input.scrollTop;
        }

        function sincronizarEditor() {
            const codigo = input.value;
            const linhas = codigo.split('\n');
            
            // 1. Atualiza números de linha
            let nums = "";
            for(let i=1; i<=linhas.length; i++) nums += i + "<br>";
            lineNumbers.innerHTML = nums;

            // 2. Análise de Erro de Sintaxe
            let linhaDoErro = -1;
            let mensagemErro = "";

            try {
                new Function(codigo);
                // Se chegar aqui, o código está OK
                highlight.innerText = codigo;
                ball.className = "w-4 h-4 rounded-full bg-emerald-500 shadow-[0_0_10px_#10b981]";
                statusMsg.innerText = "SINTAXE PERFEITA!";
                diagnostico.innerHTML = `
                    <div class="p-4 bg-emerald-900/20 border border-emerald-500/30 rounded-xl text-emerald-400 text-xs">
                        <b>✅ NADA A CORRIGIR:</b> O motor do navegador aceitou todas as funções e chaves.
                    </div>
                `;
            } catch (e) {
                mensagemErro = e.message;
                
                // Tenta descobrir a linha do erro através da mensagem
                // Motores modernos as vezes retornam "at line X"
                const match = e.stack.match(/<anonymous>:(\d+):/);
                if (match) {
                    linhaDoErro = parseInt(match[1]) - 2; // Ajuste de offset da Function
                } else {
                    // Se o motor não der a linha, procuramos por desbalanceamento de chaves
                    linhaDoErro = caçarPelaMensagem(linhas, mensagemErro);
                }

                ball.className = "w-4 h-4 rounded-full bg-red-500 shadow-[0_0_10px_#ef4444]";
                statusMsg.innerText = "ERRO IDENTIFICADO!";
                
                // Renderiza o código com destaque na linha
                renderizarDestaque(linhas, linhaDoErro);

                diagnostico.innerHTML = `
                    <div class="p-4 bg-red-600 text-white rounded-xl shadow-lg">
                        <p class="text-[9px] uppercase font-black opacity-70 mb-1">Causa da Morte:</p>
                        <p class="text-sm font-bold">${mensagemErro}</p>
                    </div>
                    <div class="p-4 bg-slate-900 border border-white/10 rounded-xl text-[11px] leading-relaxed">
                        <p class="text-indigo-400 font-bold mb-2">🔎 ANÁLISE DO SENTINELA:</p>
                        ${traduzirErro(mensagemErro, linhaDoErro)}
                    </div>
                `;
            }
            sincronizarScroll();
        }

        function renderizarDestaque(linhas, linhaErro) {
            let html = "";
            linhas.forEach((txt, idx) => {
                const safeTxt = txt.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
                if (idx + 1 === linhaErro) {
                    html += `<span class="error-highlight">${safeTxt || ' '}</span>\n`;
                } else {
                    html += safeTxt + "\n";
                }
            });
            highlight.innerHTML = html;
        }

        function caçarPelaMensagem(linhas, msg) {
            // Busca manual se o navegador for vago
            if (msg.includes("missing )") || msg.includes("argument list")) {
                for(let i=0; i<linhas.length; i++) {
                    if ((linhas[i].includes('console.log') || linhas[i].includes('alert')) && !linhas[i].includes(')')) return i + 1;
                }
            }
            if (msg.includes("Unexpected token '}'") || msg.includes("missing }")) {
               return linhas.length; // Geralmente o erro é por falta de fechamento no fim
            }
            return -1;
        }

        function traduzirErro(msg, linha) {
            let dica = "Verifique a pontuação e o fechamento de blocos.";
            if(msg.includes("missing )")) dica = "Você abriu um parêntese em uma função ou `console.log` e esqueceu de fechar `)`.";
            if(msg.includes("Unexpected token '}'")) dica = "Tem uma chave `}` sobrando, ou você esqueceu de fechar um `try` ou `if` antes dela.";
            if(msg.includes("Identifier") && msg.includes("already been declared")) dica = "Você criou duas variáveis ou funções com o mesmo nome.";
            
            return `O erro parece estar na <b>Linha ${linha}</b>.<br><br>${dica}<br><br><span class="text-gray-500 italic">Dica: Olhe sempre para a linha marcada em vermelho e para a linha imediatamente acima dela.</span>`;
        }

        // Previne o TAB de sair do campo
        input.addEventListener('keydown', function(e) {
            if (e.key == 'Tab') {
                e.preventDefault();
                var start = this.selectionStart;
                var end = this.selectionEnd;
                this.value = this.value.substring(0, start) + "    " + this.value.substring(end);
                this.selectionStart = this.selectionEnd = start + 4;
                sincronizarEditor();
            }
        });
    </script>
</body>
</html>
